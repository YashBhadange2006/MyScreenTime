<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="@color/bright_white"
    app:cardCornerRadius="24dp"
    app:cardElevation="1dp"
    app:strokeWidth="0dp"
    app:cardUseCompatPadding="@android:bool/config_enableMaterialDesignInPackageInstaller">

    <LinearLayout
        android:id="@+id/total_screen_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingTop="32dp"
        android:paddingRight="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Screen Time"
            android:textSize="18dp"
            />

        <TextView
            android:id="@+id/total_screen_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0h 0m"
            android:textSize="36dp"
            android:textStyle="bold"/>

        <!-- Description Text -->
        <TextView
            android:id="@+id/percent_comp_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.2"
            android:text="12% less than yestarday."
            android:textColor="#4A5568"
            android:textSize="16sp" />

    </LinearLayout>


</com.google.android.material.card.MaterialCardView>


