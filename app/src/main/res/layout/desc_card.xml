<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="@color/light_grey"
    app:cardCornerRadius="24dp"
    app:cardElevation="5dp"
    app:strokeWidth="0dp"
    app:cardUseCompatPadding="@android:bool/config_enableMaterialDesignInPackageInstaller">

    <LinearLayout
        app:layout_constraintTop_toBottomOf="@id/permission_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingTop="32dp"
        android:paddingRight="24dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/iv_privacy_lock"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="Privacy Lock"
            android:src="@drawable/baseline_lock_24"
            app:tint="#0066FF" />

        <!-- Description Text -->
        <TextView
            android:id="@+id/tv_privacy_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:text="Your usage data stays on your device unless you choose to generate AI insights. We prioritize your privacy through local processing and encrypted analysis."
            android:textColor="#4A5568"
            android:textSize="14sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
